# ============================================
# TERRAFORM VARIABLES - Example Configuration
# ============================================
# Copy this file to terraform.tfvars and update with your values
# NEVER commit terraform.tfvars to version control!

# ==================== General Configuration ====================
aws_region   = "us-east-1"
project_name = "singha-loyalty"
environment  = "production"  # Options: development, staging, production

# ==================== Networking ====================
vpc_cidr = "10.0.0.0/16"

# ==================== Database Configuration ====================
# IMPORTANT: Use strong passwords in production!
db_username             = "admin"
db_password             = "CHANGE_ME_MIN_8_CHARS"  # Must be at least 8 characters
db_instance_class       = "db.t3.micro"            # Options: db.t3.micro, db.t3.small, db.t3.medium
allocated_storage       = 20                        # GB
multi_az                = false                     # Set to true for production high availability
backup_retention_period = 7                         # Days (0-35)

# ==================== Application Configuration ====================
# IMPORTANT: Use a strong, random JWT secret!
jwt_secret  = "CHANGE_ME_RANDOM_32_CHAR_STRING"  # Must be at least 32 characters
cors_origin = "*"  # Update with your frontend domain in production

# ==================== Container Configuration ====================
# Leave empty to use ECR repository created by Terraform
container_image  = ""
container_cpu    = 256   # 256 = 0.25 vCPU, 512 = 0.5 vCPU, 1024 = 1 vCPU
container_memory = 512   # MB
desired_count    = 2     # Number of tasks to run

# ==================== Auto Scaling ====================
enable_autoscaling  = true
min_capacity        = 2
max_capacity        = 10
cpu_target_value    = 70   # Percentage
memory_target_value = 80   # Percentage

# ==================== Cost Optimization ====================
use_spot_instances = true   # Use Fargate Spot for cost savings
spot_weight        = 80     # Percentage of tasks on Spot (0-100)

# ==================== Monitoring ====================
enable_container_insights = true
log_retention_days        = 7  # Options: 1, 3, 5, 7, 14, 30, 60, 90, 120, 150, 180, 365, 400, 545, 731, 1827, 3653

# ==================== Frontend Configuration ====================
enable_cloudfront      = true
cloudfront_price_class = "PriceClass_100"  # Options: PriceClass_100, PriceClass_200, PriceClass_All

# ==================== Additional Tags ====================
additional_tags = {
  Owner       = "DevOps Team"
  CostCenter  = "Engineering"
  Compliance  = "GDPR"
}
