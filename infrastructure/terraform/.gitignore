# ============================================
# Terraform .gitignore
# ============================================
# NEVER commit sensitive data to version control!

# Local .terraform directories
**/.terraform/*

# .tfstate files contain sensitive data
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
tfplan

# Ignore deployment info (may contain sensitive data)
deployment-info.txt

# Ignore backup files
*.backup
*.bak

# Ignore lock files (optional - some teams commit this)
# .terraform.lock.hcl

# OS specific files
.DS_Store
Thumbs.db
desktop.ini

# IDE specific files
.vscode/
.idea/
*.swp
*.swo
*~
