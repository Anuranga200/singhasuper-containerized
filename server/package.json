{
  "name": "singha-loyalty-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Singha Loyalty System - Express Server",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "verify": "node verify-tables.js",
    "test": "vitest run",
    "test:watch": "vitest",
